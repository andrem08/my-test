    {
      "parameters": {
        "jsCode": "// Calcula diff entre extensão e DB\nconst currentRecords = $input.first().json;\nconst dbRecords = $input.last().json;\n\nconst extensionIds = new Set();\nconst currentData = {};\n\n// Se currentRecords for array, processa cada item\nif (Array.isArray(currentRecords)) {\n  currentRecords.forEach(r => {\n    extensionIds.add(r.ID);\n    currentData[r.ID] = r;\n  });\n} else if (currentRecords.ID) {\n  extensionIds.add(currentRecords.ID);\n  currentData[currentRecords.ID] = currentRecords;\n}\n\nconst dbIds = new Set();\nif (Array.isArray(dbRecords)) {\n  dbRecords.forEach(r => dbIds.add(r.ID));\n} else if (dbRecords && dbRecords.ID) {\n  dbIds.add(dbRecords.ID);\n}\n\nconst toInsert = [];\nfor (const id of extensionIds) {\n  if (!dbIds.has(id)) {\n    toInsert.push(currentData[id]);\n  }\n}\n\nconst toDelete = [];\nfor (const id of dbIds) {\n  if (!extensionIds.has(id)) {\n    toDelete.push(id);\n  }\n}\n\nconst ccId = currentData[Array.from(extensionIds)[0]]?.ID_CC || '';\nconst type = currentData[Array.from(extensionIds)[0]]?.TYPE || '';\n\nconsole.log(JSON.stringify({\n  timestamp: new Date().toISOString(),\n  route: 'cc_report',\n  event: 'diff_calculated',\n  cc_id: ccId,\n  type: type,\n  to_insert: toInsert.length,\n  to_delete: toDelete.length,\n  level: 'info'\n}));\n\nreturn {\n  json: {\n    cc_id: ccId,\n    type: type,\n    to_insert: toInsert,\n    to_delete: toDelete,\n    has_changes: toInsert.length > 0 || toDelete.length > 0\n  }\n};"
      },
