      "webhookId": "8e1d053b-4df1-4cdd-b532-bc6b596a14ed"
    },
    {
      "parameters": {
        "jsCode": "const incoming = $json ?? {}\n\nconst routeRaw = (incoming.query?.route ?? incoming.route ?? incoming.routePath ?? '').toString().trim()\nconst [routePathRaw, routeQuery = ''] = routeRaw.split('?')\nconst routePath = routePathRaw.replace(/^\\/+|\\/+$/g, '')\n\nconst requestBody = incoming.body ?? incoming.requestBody ?? {}\n\nfunction collectRows(payload) {\n  if (Array.isArray(payload)) return payload\n  if (!payload || typeof payload !== 'object') return []\n\n  if (Array.isArray(payload?.data?.source?.itens)) return payload.data.source.itens\n  if (Array.isArray(payload?.source?.itens)) return payload.source.itens\n  if (Array.isArray(payload?.itens)) return payload.itens\n  if (Array.isArray(payload?.rows)) return payload.rows\n  if (Array.isArray(payload?.items)) return payload.items\n\n  return [payload]\n}\n\nfunction norm(v) {\n  if (v === undefined) return null\n  if (typeof v !== 'string') return v\n  const t = v.trim()\n  return t === '' ? null : t\n}\n\nconst now = new Date().toISOString()\nconst routeKey = routePath || 'unknown_route'\n\nif (routePath === 'get_update_extension_service_data') {\n  return [{\n    json: {\n      _mode: 'status_refresh',\n      _routePath: routePath,\n      routePath,\n      routeQuery,\n      receivedAt: now\n    }\n  }]\n}\n\nconst rows = collectRows(requestBody)\n  .filter((row) => row && typeof row === 'object' && !Array.isArray(row))\n  .map((row) => {\n    const normalized = {}\n    for (const [k, v] of Object.entries(row)) normalized[k] = norm(v)\n    if (!Object.prototype.hasOwnProperty.call(normalized, 'updated_at')) normalized.updated_at = now\n    return {\n      ...normalized,\n      _routePath: routePath,\n      _routeKey: routeKey\n    }\n  })\n\nif (rows.length === 0) {\n  return [{\n    json: {\n      ok: false,\n      skipUpsert: true,\n      routePath,\n      routeQuery,\n      message: 'No rows found to populate for this route.',\n      receivedAt: now\n    }\n  }]\n}\n\nreturn rows.map((row) => ({ json: row }))"
      },
