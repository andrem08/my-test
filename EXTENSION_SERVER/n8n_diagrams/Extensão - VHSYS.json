      "id": "e2c0fd36-c8d9-40e2-b02f-8522f7f0dc33",
      "name": "Is get_update_extension_service_data?"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH tz AS (\n  SELECT (CURRENT_TIMESTAMP AT TIME ZONE 'America/Sao_Paulo')::timestamp AS brazil_now\n),\nupdated AS (\n  UPDATE update_extension_services u\n  SET \"LAST_UPDATE\" = tz.brazil_now\n  FROM tz\n  RETURNING u.*\n)\nSELECT\n  \"ACTION\",\n  \"RUN_AFTER\",\n  \"RUN_STATUS\",\n  \"PROGRESS_VALUE\",\n  \"LAST_RUN\",\n  \"LAST_UPDATE\",\n  CASE\n    WHEN \"LAST_RUN\" IS NULL THEN false\n    WHEN \"RUN_STATUS\" = 0 THEN false\n    ELSE ((SELECT brazil_now FROM tz) - \"LAST_RUN\") > make_interval(mins => COALESCE(\"RUN_AFTER\", 0))\n  END AS \"SHOULD_RUN\"\nFROM updated\nORDER BY \"ACTION\";",
        "options": {
          "connectionTimeout": 30,
          "queryBatching": "single",
          "replaceEmptyStrings": true
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        -1496,
        -384
      ],
      "id": "3c8a3a55-b175-4ff2-a218-d7354144f45f",
      "name": "Refresh and read extension services"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "{{ (() => {\nconst row = $json;\nconst schema = 'raw_data';\nconst routePath = String(row._routePath || row._routeKey || '').trim();\nif (!routePath) return 'SELECT 1;';\n\nconst payload = Object.fromEntries(\n  Object.entries(row).filter(([key]) => !key.startsWith('_'))\n);\n\nconst fields = Object.keys(payload).filter((key) => !key.startsWith('$') && key !== 'json' && key !== 'pairedItem');\nif (fields.length === 0) return 'SELECT 1;';\n\nconst idCandidates = [\n  'id',\n  'codigo',\n  'matricula',\n  'matricula_funcionario',\n  ...fields.filter((f) => /^id_/i.test(f)),\n  ...fields.filter((f) => /_id$/i.test(f))\n];\n\nconst conflictField = idCandidates.find((f) => fields.includes(f)) || fields[0];\n\nconst columns = fields.map((f) => quoteIdentifier(f)).join(', ');\nconst values = fields.map((f) => escapeSqlValue(payload[f])).join(', ');\nconst updateSet = fields\n  .filter((f) => f !== conflictField)\n  .map((f) => `${quoteIdentifier(f)} = EXCLUDED.${quoteIdentifier(f)}`)\n  .join(', ');\n\nconst tableRef = `${quoteIdentifier(schema)}.${quoteIdentifier(routePath)}`;\n\nif (!updateSet) {\n  return `INSERT INTO ${tableRef} (${columns}) VALUES (${values}) ON CONFLICT (${quoteIdentifier(conflictField)}) DO NOTHING;`;\n}\n\nreturn `INSERT INTO ${tableRef} (${columns}) VALUES (${values}) ON CONFLICT (${quoteIdentifier(conflictField)}) DO UPDATE SET ${updateSet};`;\n\nfunction quoteIdentifier(id) {\n  return `\"${String(id).replace(/\"/g, '\"\"')}\"`;\n}\n\nfunction escapeSqlValue(value) {\n  if (value === null || value === undefined || value === '') return 'NULL';\n  if (typeof value === 'number') return value;\n  if (typeof value === 'boolean') return value ? 'true' : 'false';\n  if (Array.isArray(value) || typeof value === 'object') {\n    return `'${JSON.stringify(value).replace(/'/g, \"''\")}'::jsonb`;\n  }\n  return `'${String(value).replace(/'/g, \"''\")}'`;\n}\n})() }}",
        "options": {
          "connectionTimeout": 30,
          "queryBatching": "single",
          "replaceEmptyStrings": true
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        -1136,
        -304
      ],
      "id": "4f8a6c74-6eff-45b9-82e9-c6f9b5502d8f",
      "name": "UPSERT raw_data.{routePath}"
    },
    {
      "parameters": {
        "jsCode": "const all = $input.all()\nconst first = all[0]?.json ?? {}\nreturn [{\n  json: {\n    ok: true,\n    routePath: first._routePath ?? null,\n    targetTable: first._routePath ? `raw_data.${first._routePath}` : null,\n    message: 'Rows upserted to Postgres schema raw_data using routePath as table name.',\n    rows_processed: all.length,\n    processed_at: new Date().toISOString()\n  }\n}]"
      },
