      "parameters": {
        "jsCode": "const actions = $input.all().map((item) => item.json)\nreturn [{\n  json: {\n    ok: true,\n    routePath: 'get_update_extension_service_data',\n    message: 'Extension services status refreshed and fetched from database.',\n    total_actions: actions.length,\n    data: actions,\n    processed_at: new Date().toISOString()\n  }\n}]"
      },
