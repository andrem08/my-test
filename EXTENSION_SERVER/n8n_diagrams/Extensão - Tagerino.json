    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const crypto = require('crypto');\n\nconst csvText = $input.item.json.data || '';\nconst empId = $('Mesclar empId').item.json.empId || '';\n\nif (!csvText || typeof csvText !== 'string') return [];\n\nconst lines = csvText.split('\\n').filter(l => l.trim());\nif (lines.length < 2) return [];\n\nconst sep = lines[0].includes(';') ? ';' : ',';\nconst headers = lines[0].split(sep).map(h => h.trim().replace(/^\"|\"$/g, '').trim());\n\nfunction createHash(s1, s2) {\n  return crypto.createHash('sha256').update(s1 + s2).digest('hex');\n}\n\nfunction timeToMinutes(timeStr) {\n  if (!timeStr || typeof timeStr !== 'string') return 0;\n  const match = timeStr.match(/^(\\d{2}):(\\d{2})$/);\n  if (!match) return 0;\n  return Number(match[1]) * 60 + Number(match[2]);\n}\n\nfunction getDatetime(dateStr, timeStr) {\n  if (!timeStr || !timeStr.trim()) return null;\n  try {\n    const [day, month, year] = dateStr.split('/');\n    const [hours, minutes] = timeStr.trim().split(':');\n    return new Date(Number(year), Number(month) - 1, Number(day), Number(hours), Number(minutes)).toISOString();\n  } catch(e) { return null; }\n}\n\nfunction formatDay(dateStr) {\n  try {\n    const [day, month, year] = dateStr.split('/');\n    return `${year}-${month.padStart(2,'0')}-${day.padStart(2,'0')}`;\n  } catch(e) { return null; }\n}\n\nconst now = new Date().toISOString();\n\nconst records = lines.slice(1)\n  .map(line => {\n    const values = line.split(sep).map(v => v.trim().replace(/^\"|\"$/g, '').trim());\n    const obj = {};\n    headers.forEach((h, i) => { obj[h] = values[i] ?? ''; });\n    return obj;\n  })\n  .filter(reg => reg['03 - DIA / MÊS'])\n  .map(reg => {\n    const DAY_REF = reg['03 - DIA / MÊS'];\n    const horasTrabalhadas = reg['05 - TRABALHADAS'] || '';\n    const horasPrevistas = reg['07 - PREVISTAS'] || '';\n    return {\n      ID: createHash(DAY_REF, empId),\n      DAY_REF,\n      DAY: formatDay(DAY_REF),\n      EMPLOYER: reg['01 - NOME'] || '',\n      EMPLOYER_CPF: reg['02 - CPF'] || '',\n      worked_hours: horasTrabalhadas,\n      worked_hours_minutes: timeToMinutes(horasTrabalhadas),\n      work_expect: horasPrevistas,\n      work_expect_minutes: timeToMinutes(horasPrevistas),\n      TURN_01_START: getDatetime(DAY_REF, reg['09 - TURNO 1 - INICIO']),\n      TURN_01_END:   getDatetime(DAY_REF, reg['10 - TURNO 1 - FIM']),\n      TURN_02_START: getDatetime(DAY_REF, reg['11 - TURNO 2 - INICIO']),\n      TURN_02_END:   getDatetime(DAY_REF, reg['12 - TURNO 2 - FIM']),\n      TURN_03_START: getDatetime(DAY_REF, reg['13 - TURNO 3 - INICIO']),\n      TURN_03_END:   getDatetime(DAY_REF, reg['14 - TURNO 3 - FIM']),\n      TURN_04_START: getDatetime(DAY_REF, reg['15 - TURNO 4 - INICIO']),\n      TURN_04_END:   getDatetime(DAY_REF, reg['16 - TURNO 4 - FIM']),\n      created_at: now,\n      updated_at: now\n    };\n  });\n\nreturn records.map(r => ({ json: r }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
