    {
      "parameters": {
        "jsCode": "const token = $('Webhook').first().json.body.tangerino_token;\nconst START_LIMIT = new Date('2020-01-01');\n\nfunction getDateBefore(dateStr, days) {\n  const d = new Date(dateStr);\n  d.setUTCDate(d.getUTCDate() - days);\n  return d.toISOString().split('T')[0];\n}\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const empId = String(item.json.id);\n  let endDate = new Date().toISOString().split('T')[0];\n\n  while (new Date(endDate) > START_LIMIT) {\n    let startDate = getDateBefore(endDate, 1600);\n    if (new Date(startDate) < START_LIMIT) startDate = '2020-01-01';\n    output.push({ json: { empId, token, startDate, endDate } });\n    endDate = getDateBefore(startDate, 20);\n  }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
