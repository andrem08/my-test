    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  \"ACTION\",\n  \"RUN_AFTER\",\n  \"RUN_STATUS\",\n  \"PROGRESS_VALUE\",\n  \"LAST_RUN\",\n  \"LAST_UPDATE\",\n  CASE\n    WHEN \"LAST_RUN\" IS NULL         THEN false\n    WHEN \"RUN_STATUS\" = 0           THEN false\n    ELSE\n      EXTRACT(EPOCH FROM (\n        (CURRENT_TIMESTAMP AT TIME ZONE 'America/Sao_Paulo')::timestamp\n        - \"LAST_RUN\"\n      )) / 60 > COALESCE(\"RUN_AFTER\", 720)\n  END AS \"SHOULD_RUN\"\nFROM auxiliary.update_extension_services\nORDER BY \"ACTION\";",
        "options": {
          "connectionTimeout": 30,
          "queryBatching": "single"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.3,
      "position": [
        -1472,
